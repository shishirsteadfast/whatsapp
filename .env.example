# OpenWA configuration
#
# Copy this file to `.env` in the project root and adjust as needed.
# Load order (later sources do NOT override earlier ones): process env >
# `.env` > `data/.env.generated` (see src/main.ts). Anything set here always
# wins over the auto-generated defaults.

# ── Server ───────────────────────────────────────────────────────────────
PORT=2785
NODE_ENV=development
# Comma-separated list of allowed origins, or * to allow any
CORS_ORIGINS=*
# Public URLs, used when generating links back to the API/dashboard
BASE_URL=
DASHBOARD_URL=
DASHBOARD_PORT=2886

# ── Auth ─────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=24h

# ── Database (SQLite only) ────────────────────────────────────────────────
DATABASE_NAME=./data/openwa.sqlite
DATABASE_SYNCHRONIZE=true
DATABASE_LOGGING=false

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=0
# Let OpenWA manage a Redis container for you (requires Docker)
REDIS_BUILTIN=false
# Enable BullMQ-backed message/webhook queues (requires REDIS_ENABLED=true)
QUEUE_ENABLED=false

# ── Storage ──────────────────────────────────────────────────────────────
# STORAGE_TYPE=local or s3
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/media

# S3-compatible settings (used when STORAGE_TYPE=s3)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=openwa
# Let OpenWA manage a MinIO container for you (requires Docker)
MINIO_BUILTIN=false

# ── WhatsApp Engine ──────────────────────────────────────────────────────
ENGINE_TYPE=whatsapp-web.js
PUPPETEER_HEADLESS=true
PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox
SESSION_DATA_PATH=./data/sessions

# ── Webhooks ─────────────────────────────────────────────────────────────
WEBHOOK_TIMEOUT=10000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=5000

# ── Rate limiting ────────────────────────────────────────────────────────
RATE_LIMIT_SHORT_TTL=1000
RATE_LIMIT_SHORT_LIMIT=10
RATE_LIMIT_MEDIUM_TTL=60000
RATE_LIMIT_MEDIUM_LIMIT=100
RATE_LIMIT_LONG_TTL=3600000
RATE_LIMIT_LONG_LIMIT=1000
