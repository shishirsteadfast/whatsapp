      },
      "queueRedis": {
        "label": "إعدادات قائمة الانتظار متسقة",
        "fix": "يتطلب QUEUE_ENABLED=true أن يكون REDIS_ENABLED=true. قم بتفعيل Redis أو تعطيل قائمة الانتظار."
