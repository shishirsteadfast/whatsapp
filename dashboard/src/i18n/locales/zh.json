        "401": "Unauthorized（未授权）——API 密钥缺失或无效。",
        "403": "Forbidden（禁止访问）——该 API 密钥没有执行此操作的权限。",
        "404": "Not Found（未找到）——请求的资源不存在。",
        "429": "Too Many Requests（请求过多）——您已超出频率限制。",
        "500": "Server Error（服务器错误）——OpenWA 服务器端出现了问题。"
      }
