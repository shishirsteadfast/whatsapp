      },
      "sessionStorage": {
        "label": "אחסון הסשן של WhatsApp ניתן לכתיבה",
        "fix": "ודאו ש-SESSION_DATA_PATH מפנה לתיקייה קיימת וניתנת לכתיבה, כדי שניתן יהיה לשמור את סשני ה-WhatsApp."
      },
      "fileStorage": {
        "label": "אחסון הקבצים מוגדר וניתן לגישה",
        "fix": "לאחסון מקומי, ודאו ש-STORAGE_LOCAL_PATH ניתן לכתיבה. לאחסון S3/MinIO, הגדירו כנדרש את S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY ו-S3_BUCKET."
      },
      "redis": {
        "label": "Redis נגיש",
        "fix": "בדקו ש-REDIS_HOST/REDIS_PORT מפנים למופע Redis פעיל, וש-REDIS_PASSWORD (אם קיים) נכון. ניתן גם להגדיר REDIS_BUILTIN=true כדי לאפשר ל-OpenWA להפעיל מופע כזה אוטומטית באמצעות Docker."
      },
      "queueRedis": {
        "label": "תצורת התור עקבית",
        "fix": "QUEUE_ENABLED=true מחייב את REDIS_ENABLED=true. יש להפעיל את Redis או להשבית את התור."
      },
