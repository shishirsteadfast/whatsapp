    "items": {
      "jwtSecret": {
        "label": "Il JWT secret è configurato in modo sicuro",
        "fix": "Impostare un JWT_SECRET forte e casuale (almeno 32 caratteri) nel file .env, quindi riavviare il server. Non utilizzare mai il valore predefinito segnaposto in produzione."
      },
      "database": {
        "label": "Il database è accessibile",
        "fix": "Assicurarsi che il file del database SQLite e la relativa cartella (DATABASE_NAME) esistano e siano scrivibili dal processo che esegue OpenWA."
      },
      "sessionStorage": {
        "label": "L'archiviazione delle sessioni WhatsApp è scrivibile",
        "fix": "Assicurarsi che SESSION_DATA_PATH punti a una cartella esistente e scrivibile, in modo che le sessioni WhatsApp possano essere salvate."
      },
      "fileStorage": {
        "label": "L'archiviazione dei file è configurata e raggiungibile",
        "fix": "Per l'archiviazione locale, assicurarsi che STORAGE_LOCAL_PATH sia scrivibile. Per l'archiviazione S3/MinIO, impostare correttamente S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY e S3_BUCKET."
      },
      "redis": {
        "label": "Redis è raggiungibile",
        "fix": "Verificare che REDIS_HOST/REDIS_PORT puntino a un'istanza Redis attiva e che REDIS_PASSWORD (se presente) sia corretta. È possibile anche impostare REDIS_BUILTIN=true per far avviare automaticamente Redis a OpenWA tramite Docker."
      },
      "queueRedis": {
        "label": "La configurazione della coda è coerente",
        "fix": "QUEUE_ENABLED=true richiede REDIS_ENABLED=true. Abilitare Redis oppure disabilitare la coda."
      },
      "dockerSocket": {
        "label": "Docker è accessibile per i servizi integrati",
        "fix": "REDIS_BUILTIN/MINIO_BUILTIN richiedono l'accesso al socket Docker. Montare /var/run/docker.sock nel container, installare Docker sull'host, oppure disabilitare queste opzioni integrate ed eseguire Redis/MinIO autonomamente."
      },
      "diskSpace": {
        "label": "È disponibile spazio su disco sufficiente",
        "fix": "Liberare spazio su disco sul volume che contiene i dati di OpenWA (database, sessioni, media). Si consigliano almeno 500MB liberi."
      },
      "cors": {
        "label": "Le origini CORS sono configurate per la produzione",
        "fix": "Impostare CORS_ORIGINS con un elenco separato da virgole delle origini dashboard/API consentite prima dell'esecuzione in produzione."
      }
    }
  },
