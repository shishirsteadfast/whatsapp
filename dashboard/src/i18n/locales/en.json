      },
      "database": {
        "label": "Database is accessible",
        "fix": "Ensure the SQLite database file and its folder (DATABASE_NAME) exist and are writable by the process running OpenWA."
      },
      "sessionStorage": {
        "label": "WhatsApp session storage is writable",
        "fix": "Ensure SESSION_DATA_PATH points to a folder that exists and is writable, so WhatsApp sessions can be saved."
      },
      "fileStorage": {
        "label": "File storage is configured and reachable",
        "fix": "For local storage, ensure STORAGE_LOCAL_PATH is writable. For S3/MinIO storage, set S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY and S3_BUCKET correctly."
      },
      "redis": {
        "label": "Redis is reachable",
        "fix": "Check that REDIS_HOST/REDIS_PORT point to a running Redis instance, and REDIS_PASSWORD (if any) is correct. You can also set REDIS_BUILTIN=true to let OpenWA start one automatically via Docker."
      },
      "queueRedis": {
        "label": "Queue configuration is consistent",
        "fix": "QUEUE_ENABLED=true requires REDIS_ENABLED=true. Either enable Redis or disable the queue."
      },
      "dockerSocket": {
        "label": "Docker is accessible for built-in services",
        "fix": "REDIS_BUILTIN/MINIO_BUILTIN require access to the Docker socket. Mount /var/run/docker.sock into the container, install Docker on the host, or disable these built-in options and run Redis/MinIO yourself."
      },
      "diskSpace": {
        "label": "Sufficient disk space is available",
        "fix": "Free up disk space on the volume storing OpenWA's data (database, sessions, media). At least 500MB free is recommended."
      },
      "cors": {
        "label": "CORS origins are configured for production",
        "fix": "Set CORS_ORIGINS to a comma-separated list of allowed dashboard/API origins before running in production."
      }
    }
